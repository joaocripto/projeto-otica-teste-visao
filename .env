# ===== GOOGLE SHEETS WEBHOOK (Apps Script) =====
# Cole aqui a URL do Apps Script que você vai criar
# Esse é o método mais simples para conectar com Google Sheets
GOOGLE_SHEETS_WEBHOOK=https://script.google.com/macros/s/AKfycbz2j2EwaFnG6hQRz13okYs_byhrDCCi2Lw-QzmcO-LpFJ1z2mbuSyaS-xE9MVvqOGw5_w/exec

# ===== CONFIGURAÇÃO OPCIONAL: GOOGLE SHEETS COM SERVICE ACCOUNT =====
# Só preenche se quiser usar a forma clássica (mais complexa)
# GOOGLE_SHEET_ID=1E6zv2S6vNEGuKtPfUKFdzfp1mOiYtMmICpP0bW1LNyc
# GOOGLE_SERVICE_ACCOUNT_EMAIL=seu-email-de-servico@seu-projeto.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSua_chave_aqui\n-----END PRIVATE KEY-----\n"

# ===== CONFIGURAÇÃO OPCIONAL: FIREBASE =====
# Descomenta isso se preferir usar Firebase em vez de Google Sheets
# FIREBASE_TYPE=service_account
# FIREBASE_PROJECT_ID=seu-projeto-firebase
# FIREBASE_PRIVATE_KEY_ID=sua-chave-privada-id
# FIREBASE_CLIENT_EMAIL=seu-email@seu-projeto.iam.gserviceaccount.com
# FIREBASE_CLIENT_ID=seu-client-id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSua_chave_firebase\n-----END PRIVATE KEY-----\n"

# ===== SERVIDOR =====
PORT=3000
NODE_ENV=production
